//////////////// BEZ DOTYKU
let bdTimer;

function bdIntro(){
  app.innerHTML=`
  <h3>${team}</h3>
  <h2>Bez dotyku</h2>
  <button onclick="startBD()">Start</button>`;
}

function startBD(startTime=null){

  if(!startTime){
    startTime = Date.now();
  }

  saveState({station:9,startTime});

  app.innerHTML=`
  <h2 id="bdTimer"></h2>
  <button onclick="stopBD()">Stop</button>`;

  bdTimer=setInterval(()=>{
    let t = Math.floor((Date.now()-startTime)/1000);

    const el=document.getElementById("bdTimer");
    if(el){
      el.innerText =
        Math.floor(t/60)+":"+(t%60<10?"0":"")+t%60;
    }

    saveState({station:9,startTime});

  },1000);
}

function stopBD(){
  clearInterval(bdTimer);

  const text = document.getElementById("bdTimer").innerText;

  app.innerHTML=`
  <h2>${text}</h2>
  <button onclick="finishBD()">Hotovo</button>`;
}

function finishBD(){
  send({station:9,answer:document.getElementById("bdTimer").innerText});
  confirmScreen();
}

