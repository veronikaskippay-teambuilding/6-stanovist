//////////////// ✅ RESTORE (KRITICKÁ ČÁST)
function restoreState(s){

  switch(s.station){

    case 1: startSlepec(s.endTime); break;
    case 3: startMemory(s.endTime); break;
    case 4: startPuzzle(s.start); break;
    case 6: showNum(s.index); break;
    case 7: showGeo(s.index, s.answers || []); break;
    case 8: showPrislovi(s.index, s.answers || []); break;
    case 9: startBD(s.startTime); break;
    case 10: startVideohry(); break;
    case 11: vlastovka(); break;
    case 12: showMath(s.index); break;
    case 13: showZaklad(s.index); break;

    default: runStation();
  }
}

</script>
