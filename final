<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mozková olympiáda</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Luckiest+Guy&display=swap" rel="stylesheet">

<style>
body{
  font-family:'Poppins',sans-serif;
  margin:0;
  padding:12px;
  background:#f5f5f5;
  color:#1f4bc1;
  max-width:480px;
  margin:auto;
}
h2{font-family:'Luckiest Guy';font-size:32px;}
button{
  background:#1f4bc1;color:#fff;border:none;
  border-radius:20px;padding:14px;width:100%;
  font-size:16px;margin-top:8px;
}
textarea,input{
  width:100%;padding:12px;font-size:16px;
  border-radius:10px;border:1px solid #ddd;
}
textarea{min-height:100px;}
.team{color:gray;font-size:12px;}
img{width:100%;max-width:300px;border-radius:10px;}
</style>
</head>

<body>

<div id="start">
<h2>Mozková olympiáda</h2>
<input id="teamInput" placeholder="Název týmu">
<br><br>
<button onclick="saveTeam()">Start</button>
</div>

<div id="app"></div>

<script>
const scriptURL="https://script.google.com/macros/s/AKfycbzVIxT_PPm6GRhmVuHvVA6UlFQI93FdNa7PqMkcAUXQRoOxhiwV59Wzbta9D9VWSO1cFQ/exec";

let team=localStorage.getItem("team");
const station=Number(new URLSearchParams(window.location.search).get("station"));

function saveState(data){
  const current = JSON.parse(localStorage.getItem("gameState")) || {};
  const updated = {...current, ...data};
  localStorage.setItem("gameState", JSON.stringify(updated));
}

function loadState(){
  return JSON.parse(localStorage.getItem("gameState"));
}

function clearState(){
  localStorage.removeItem("gameState");
}

function send(data){
  fetch(scriptURL,{
    method:"POST",
    mode:"no-cors",
    body:JSON.stringify({team:team,...data})
  });
}

function confirmScreen(){
  clearState();
  document.getElementById("app").innerHTML=`<h2>✅ Hotovo!</h2>`;
}

if(team){ startApp(); }

function saveTeam(){
  team=document.getElementById("teamInput").value;
  localStorage.setItem("team",team);
  startApp();
}

function startApp(){
  document.getElementById("start").style.display="none";

  const s = loadState();

  if(s && s.station === station){
    restoreState(s);
  } else {
    runStation();
  }
}

function runStation(){
  if(station===1) slepecIntro();
  if(station===2) tichaPosta();
  if(station===3) memoryIntro();
  if(station===4) puzzleIntro();
  if(station===5) plakatIntro();
  if(station===6) numberIntro();
  if(station===7) geoIntro();
  if(station===8) prisloviIntro();
  if(station===9) bdIntro();
  if(station===10) videohryIntro();
  if(station===11) vlastovka();
  if(station===12) matematikaIntro();
  if(station===13) zakladIntro();
}

function getTimeLeft(endTime){
  return Math.max(0, Math.floor((endTime - Date.now())/1000));
}

//////////////// SLEPEC
let slepecTimer;

function slepecIntro(){
  app.innerHTML=`<h3>${team}</h3><h2>Slepec</h2><button onclick="startSlepec()">Start</button>`;
}

function startSlepec(endTime=null){
  if(!endTime){
    endTime = Date.now() + 4*60*1000;
  }

  saveState({station:1,endTime});

  app.innerHTML=`<h2 id="t"></h2><button onclick="finishSlepec()">Hotovo</button>`;

  slepecTimer=setInterval(()=>{
    let t = getTimeLeft(endTime);

    saveState({station:1,endTime});

    document.getElementById("t").innerText =
      Math.floor(t/60)+":"+(t%60<10?"0":"")+t%60;

  },1000);
}

function finishSlepec(){
  clearInterval(slepecTimer);
  send({station:1,answer:"PHOTO"});
  confirmScreen();
}

//////////////// MEMORY
let memTimer;

function memoryIntro(){
  app.innerHTML=`<h3>${team}</h3><h2>Memory</h2><button onclick="startMemory()">Start</button>`;
}

function startMemory(endTime=null){
  if(!endTime){
    endTime = Date.now() + 4*60*1000;
  }

  saveState({station:3,endTime});

  app.innerHTML=`<h2 id="mt"></h2>
  <textarea id="txt"></textarea>
  <button onclick="finishMemory()">Hotovo</button>`;

  memTimer=setInterval(()=>{
    let t = getTimeLeft(endTime);

    document.getElementById("mt").innerText =
      Math.floor(t/60)+":"+(t%60<10?"0":"")+t%60;

    saveState({station:3,endTime});

  },1000);
}

function finishMemory(){
  clearInterval(memTimer);
  send({station:3,answer:document.getElementById("txt").value});
  confirmScreen();
}

//////////////// PUZZLE
let pTimer,pStart;

function puzzleIntro(){
  app.innerHTML=`<h3>${team}</h3><h2>Puzzle</h2><button onclick="startPuzzle()">Start</button>`;
}

function startPuzzle(start=null){
  if(!start) start = Date.now();

  saveState({station:4,start});

  app.innerHTML=`<h2 id="pt"></h2><button onclick="stopPuzzle()">Stop</button>`;

  pTimer=setInterval(()=>{
    let t = Math.floor((Date.now()-start)/1000);

    document.getElementById("pt").innerText =
      Math.floor(t/60)+":"+(t%60<10?"0":"")+t%60;

    saveState({station:4,start});

  },1000);
}

function stopPuzzle(){
  clearInterval(pTimer);

  const text=document.getElementById("pt").innerText;

  app.innerHTML=`<h2>${text}</h2><button onclick="finishPuzzle()">Hotovo</button>`;
}

function finishPuzzle(){
  send({station:4,answer:document.getElementById("pt").innerText});
  confirmScreen();
}
``

//////////////// TICHÁ POŠTA
function tichaPosta(){
