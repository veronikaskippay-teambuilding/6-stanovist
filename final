//////////////// PLAKÁT
function plakatIntro(){
  app.innerHTML=`
  <h3>${team}</h3>
  <h2>Plakát</h2>
  <button onclick="startPlakat()">Start</button>`;
}

function startPlakat(){
  saveState({station:5});

  app.innerHTML=`
  <textarea id="p"></textarea>
  <button onclick="finishPlakat()">Hotovo</button>`;
}

function finishPlakat(){
  send({station:5,answer:document.getElementById("p").value});
