function prisloviIntro(){
  app.innerHTML=`<h3>${team}</h3><h2>Přísloví</h2>
  <button onclick="startPrislovi()">Start</button>`;
}

function startPrislovi(){
  showPrislovi(0,[]);
}

function showPrislovi(index,answers){

  saveState({station:8,index,answers});

  app.innerHTML=`
  <h2>${index+1}/10</h2>
  <img src="${prislovi[index]}">
  <input id="prInput">
  <button onclick="nextPrislovi(${index},${JSON.stringify(answers).replace(/"/g,'&quot;')})">Další</button>`;
